# =============================================================================
# SOCRA 환경변수 예시 (.env.example)
# 실제 비밀 값은 이 파일이 아니라 .env.local / 배포 환경변수에 넣으세요.
# .env, .env.local 은 .gitignore 로 커밋되지 않습니다.
# =============================================================================

# ── 운영 모드 ────────────────────────────────────────────────────────────────
# single  : 기존 단일 사용자 모드 (서버 OPENROUTER_API_KEY 하나로 동작). 기본값.
# platform: 다중 교사 공유 플랫폼 (교사 로그인 · 교사별 키 · 반별 학생 링크).
APP_MODE=single

# ── single 모드 전용 ─────────────────────────────────────────────────────────
# APP_MODE=single 일 때만 사용됩니다.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
OPENROUTER_TUTOR_MODEL=google/gemini-2.5-flash
OPENROUTER_SOLVER_MODEL=google/gemini-2.5-flash
# 사내 프록시 등에서 TLS 검증이 필요 없을 때만 true (운영 환경에서는 false 권장)
OPENROUTER_ALLOW_INSECURE_TLS=false

# ── platform 모드 전용 ───────────────────────────────────────────────────────
# 앱 공개 URL (학생 링크·QR·매직링크 리다이렉트에 사용). 예: https://socra.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase 프로젝트 설정 → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용. 절대 클라이언트에 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# 교사 API 키 암호화 마스터 키 (AES-256-GCM, 32바이트).
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=

# 관리자 권한을 가질 이메일(쉼표 구분). 예: owner@example.com,admin@example.com
PLATFORM_OWNER_EMAILS=

# ── 공통 ─────────────────────────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=8
